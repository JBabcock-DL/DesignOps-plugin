{
  "$schema": "shadcn/ui + inverse surface legacy alias mappings for tokens.css Step 13b. These --legacy-name aliases map to the canonical --color-* tokens so shadcn components work without changes.",
  "lightAndDark": [
    { "alias": "--background",             "from": "--color-background" },
    { "alias": "--on-background",          "from": "--color-content" },
    { "alias": "--foreground",             "from": "--color-content" },
    { "alias": "--background-inverse",     "from": "--color-inverse-surface" },
    { "alias": "--foreground-inverse",     "from": "--color-inverse-content" },
    { "alias": "--surface-raised",         "from": "--color-background-variant" },
    { "alias": "--surface-overlay",        "from": "--color-background-container-highest" },
    { "alias": "--border",                 "from": "--color-border" },
    { "alias": "--border-subtle",          "from": "--color-border-subtle" },
    { "alias": "--primary",                "from": "--color-primary" },
    { "alias": "--on-primary",             "from": "--color-on-primary" },
    { "alias": "--primary-container",      "from": "--color-primary-subtle" },
    { "alias": "--on-primary-container",   "from": "--color-on-primary-subtle" },
    { "alias": "--primary-foreground",     "from": "--color-on-primary" },
    { "alias": "--primary-subtle",         "from": "--color-primary-subtle" },
    { "alias": "--on-primary-subtle",      "from": "--color-on-primary-subtle" },
    { "alias": "--secondary",              "from": "--color-secondary" },
    { "alias": "--on-secondary",           "from": "--color-on-secondary" },
    { "alias": "--secondary-container",    "from": "--color-secondary-subtle" },
    { "alias": "--on-secondary-container", "from": "--color-on-secondary-subtle" },
    { "alias": "--secondary-foreground",   "from": "--color-on-secondary" },
    { "alias": "--secondary-subtle",       "from": "--color-secondary-subtle" },
    { "alias": "--on-secondary-subtle",    "from": "--color-on-secondary-subtle" },
    { "alias": "--tertiary",               "from": "--color-accent" },
    { "alias": "--on-tertiary",            "from": "--color-on-accent" },
    { "alias": "--tertiary-container",     "from": "--color-accent-subtle" },
    { "alias": "--on-tertiary-container",  "from": "--color-on-accent-subtle" },
    { "alias": "--accent",                 "from": "--color-accent-subtle" },
    { "alias": "--accent-foreground",      "from": "--color-on-accent-subtle" },
    { "alias": "--destructive",            "from": "--color-danger" },
    { "alias": "--destructive-foreground", "from": "--color-on-danger" },
    { "alias": "--error",                  "from": "--color-danger" },
    { "alias": "--on-error",               "from": "--color-on-danger" },
    { "alias": "--error-container",        "from": "--color-danger-subtle" },
    { "alias": "--on-error-container",     "from": "--color-on-danger-subtle" },
    { "alias": "--error-subtle",           "from": "--color-danger-subtle" },
    { "alias": "--on-error-subtle",        "from": "--color-on-danger-subtle" },
    { "alias": "--input",                  "from": "--color-field" },
    { "alias": "--ring",                   "from": "--color-focus-ring" },
    { "alias": "--sidebar",                "from": "--color-sidebar" },
    { "alias": "--sidebar-foreground",     "from": "--color-on-sidebar" },
    { "alias": "--card",                   "from": "--color-background" },
    { "alias": "--card-foreground",        "from": "--color-content" },
    { "alias": "--popover",                "from": "--color-background-container-highest" },
    { "alias": "--popover-foreground",     "from": "--color-content" },
    { "alias": "--muted",                  "from": "--color-background-variant" },
    { "alias": "--muted-foreground",       "from": "--color-content-muted" }
  ],
  "bodyVariantDecorationHelpers": {
    "$note": "Declare once in :root — these do not change per theme or font-scale.",
    "properties": [
      { "name": "--body-link-text-decoration",          "value": "underline" },
      { "name": "--body-strikethrough-text-decoration", "value": "line-through" },
      { "name": "--body-link-color",                    "value": "var(--color-primary)" },
      { "name": "--body-strikethrough-color",           "value": "var(--color-content-muted)" }
    ]
  }
}
