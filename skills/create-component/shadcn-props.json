{
  "$schema": "./shadcn-props.schema.json",
  "$comment": "Curated per-component prop map consumed by /create-component Mode A. One entry per shadcn/ui component in the routing table. Each entry supplies: `properties` (Properties+Types table rows [name, type, default, required, description]), `componentProps` flags (which element component properties to create), `iconSlots` config (24x24 placeholder frames), `pageName` (target Figma page from routing table), `labelKey` (which cva variant axis drives the Figma `variant` property; the other axis becomes `size`), and `summary` (one sentence for the doc header). For components where Mode A cva extraction succeeds, these entries are merged with the extracted variants/sizes/defaults and the resolved classname token bindings. When Mode A is unavailable (shadcn not installed, source import fails), the entry alone drives Mode B synthetic rendering.",

  "button": {
    "pageName": "\u21b3 Buttons",
    "labelKey": "variant",
    "summary": "Trigger an action or navigate. Follows shadcn/ui defaults \u2014 visual variants and size presets.",
    "iconSlots": { "leading": true, "trailing": true, "size": 24 },
    "componentProps": { "label": true, "leadingIcon": true, "trailingIcon": true },
    "properties": [
      ["variant", "enum", "\"default\"", "no", "Visual style."],
      ["size", "enum", "\"default\"", "no", "Overall height + padding preset."],
      ["disabled", "boolean", "false", "no", "Disables pointer + keyboard interaction; adds visual dim."],
      ["asChild", "boolean", "false", "no", "Renders styled classes onto the immediate child via Radix Slot."],
      ["type", "\"button\" | \"submit\" | \"reset\"", "\"button\"", "no", "Native HTML button type."],
      ["className", "string", "\u2014", "no", "Tailwind class escape hatch."]
    ]
  },

