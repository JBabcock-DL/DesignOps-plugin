{
  "$schema": "./shadcn-props.schema.json",
  "$comment": "Curated per-component prop map consumed by /create-component Mode A. Keys are kebab-case and should match every component listed under https://ui.shadcn.com/docs/components (install name from `npx shadcn add <name>`). Each entry supplies: `properties` (Properties+Types table rows [name, type, default, required, description]), `componentProps`, `iconSlots`, `pageName` (Detroit Labs Foundations page from /new-project scaffold), `labelKey` (cva axis for Figma `variant` when present), `summary`, and optional `composes`. Mode A merges with extract-cva + resolve-classes; missing source falls back to Mode B synthetic CONFIG.",

  "button": {
    "pageName": "\u21b3 Buttons",
    "labelKey": "variant",
    "summary": "Trigger an action or navigate. Follows shadcn/ui defaults \u2014 visual variants and size presets.",
    "iconSlots": { "leading": true, "trailing": true, "size": 24 },
    "componentProps": { "label": true, "leadingIcon": true, "trailingIcon": true },
    "properties": [
      ["variant", "enum", "\"default\"", "no", "Visual style."],
      ["size", "enum", "\"default\"", "no", "Overall height + padding preset."],
      ["disabled", "boolean", "false", "no", "Disables pointer + keyboard interaction; adds visual dim."],
      ["asChild", "boolean", "false", "no", "Renders styled classes onto the immediate child via Radix Slot."],
      ["type", "\"button\" | \"submit\" | \"reset\"", "\"button\"", "no", "Native HTML button type."],
      ["className", "string", "\u2014", "no", "Tailwind class escape hatch."]
    ]
  },

  "button-group": {
    "pageName": "\u21b3 Button Group",
    "labelKey": "variant",
    "summary": "Grouped buttons for related actions (orientation + shared variant/size).",
    "composes": [
      {
        "component": "button",
        "slot": "items",
        "cardinality": "many",
        "count": 3,
        "defaultProps": { "variant": "outline", "size": "default" }
      }
    ],
    "iconSlots": { "leading": false, "trailing": false, "size": 24 },
    "componentProps": { "label": false, "leadingIcon": false, "trailingIcon": false },
    "properties": [
      ["variant", "enum", "\"default\"", "no", "Visual style applied to member buttons."],
      ["size", "enum", "\"default\"", "no", "Size preset for member buttons."],
      ["orientation", "\"horizontal\" | \"vertical\"", "\"horizontal\"", "no", "Layout axis of the group."],
      ["asChild", "boolean", "false", "no", "Renders onto child via Radix Slot."],
      ["className", "string", "\u2014", "no", "Tailwind class escape hatch."]
    ],
    "usageDo": [
      "Keep related actions in one group so spacing and focus order stay predictable.",
      "Use `orientation=\"vertical\"` only when horizontal space is constrained.",
      "Rely on member `Button` instances from `↳ Buttons` so paint updates propagate.",
      "Expose at most one primary `default` button per group."
    ],
    "usageDont": [
      "Do not mix unrelated actions into one group — split into separate groups.",
      "Do not detach member buttons from the `Button` ComponentSet.",
      "Do not override member sizing with ad-hoc frames — use the `size` prop.",
      "Do not nest another full `ButtonGroup` inside a single group cell."
    ]
  },

