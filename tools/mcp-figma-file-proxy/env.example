# Copy to a local, untracked file or paste into your IDE MCP `env` block.
# Never commit real tokens.
#
# FIGMA_MCP_ACCESS_TOKEN=   # Bearer — required for forward to https://mcp.figma.com/mcp
# FIGMA_MCP_UPSTREAM_URL=   # Optional. Default: https://mcp.figma.com/mcp
#
# Comma- or (on POSIX) colon-separated list of directories `mcpArgsPath` may resolve under.
# On Windows, use ";" as separator, or a single path.
# FIGMA_MCP_READ_ROOTS=
#
# Optional: single workspace / design repo root (always allowed in addition to READ_ROOTS).
# FIGMA_MCP_WORKSPACE_ROOT=
#
# Optional: override check script (default: DesignOps repo scripts/check-use-figma-mcp-args.mjs).
# FIGMA_MCP_CHECK_SCRIPT=
#
# DEBUG=figma-mcp-proxy      # log path hash + file size to stderr (no secrets)
#
# FIGMA_MCP_TEST_MOCK=1      # tests only: stub upstream use_figma
